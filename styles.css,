.spinner{
  width: 40px;
    height: 40px;
    border: 4px solid #ccc;
    border-top: 4px solid #333;
    border-radius: 50%;
    margin: 20px auto;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.country-card{
    background-color: blue;
    padding: 20px;
}

.border-grid{
    display:flex;
    flex-direction: column;
    
}

.error{
    color: red;
    font-weight: bold; 

}
.hidden {
    display: none;
}